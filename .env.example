APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MARKET_QUEUE_NAME=market

REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME=http

TELEGRAM_BOT_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_CHAT_ID=
TELEGRAM_BOT_TIMEOUT=10

BALE_BOT_BASE_URL=https://tapi.bale.ai
BALE_BOT_TOKEN=
BALE_BOT_CHAT_ID=
BALE_BOT_TIMEOUT=10

PUSHE_ENABLED=false
PUSHE_LEGACY_USER_TARGETING=true
PUSHE_BASE_URL=https://api.pushe.co
PUSHE_APP_ID=
PUSHE_API_TOKEN=
PUSHE_TIMEOUT=10

FCM_ENABLED=false
FCM_BASE_URL=https://fcm.googleapis.com/v1
FCM_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FCM_TIMEOUT=10

# Local-only phone verification sender. Replace with a real provider adapter
# and configuration before enabling phone verification in production.
PHONE_VERIFICATION_DRIVER=log
PHONE_VERIFICATION_CODE_TTL_SECONDS=600
PHONE_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
PHONE_VERIFICATION_MAX_ATTEMPTS=5
